{
  "expo": {
    "name": "SideKick",
    "slug": "sidekick",
    "version": "1.0.0",
    "orientation": "default",
    "icon": "./assets/images/logo-1024.png",
    "scheme": "sidekick",
    "userInterfaceStyle": "automatic",
    "backgroundColor": "#F9FAFB",
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#1a1a1a",
        "foregroundImage": "./assets/images/logo-1024.png"
      },
      "predictiveBackGestureEnabled": false,
      "package": "com.sidekickai.app",
      "googleServicesFile": "./google-services.json",
      "permissions": [
        "android.permission.INTERNET",
        "android.permission.ACCESS_NETWORK_STATE",
        "android.permission.READ_MEDIA_IMAGES",
        "android.permission.POST_NOTIFICATIONS",
        "android.permission.VIBRATE"
      ]
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/logo-1024.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-image-picker",
        {
          "photosPermission": "SideKick AI needs access to your photo library to upload screenshots.",
          "cameraPermission": false
        }
      ],
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/logo-1024.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ],
      "@react-native-google-signin/google-signin"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "19273525-8729-4d23-ac51-14b882fff1d1"
      }
    }
  }
}